# Connection: provide DATABASE_URL, or the discrete DB_* vars below.
DATABASE_URL=postgres://student:student@localhost:5432/student_course?sslmode=disable

# Discrete settings (used to build a DSN when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USER=student
DB_PASSWORD=student
DB_NAME=student_course
DB_SSLMODE=disable

# HTTP server
HTTP_PORT=8080

# Logging: debug | info | warn | error
LOG_LEVEL=info
